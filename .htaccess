# ── Root .htaccess – Assignment Portal ──────────────────────────────────────
RewriteEngine On
RewriteBase /ass/

# Block direct access to sensitive directories
RewriteRule ^includes(/|$) - [F,L]
RewriteRule ^uploads(/|$)  - [F,L]

# ── 301 Canonical: strip .php from the browser address bar ───────────────────
# /ass/admin/anything.php  →  /ass/admin
RewriteCond %{THE_REQUEST} \s/+ass/admin/[^/?]+\.php [NC]
RewriteRule ^ /ass/admin [R=301,L]

# /ass/X.php  →  /ass/X
RewriteCond %{THE_REQUEST} \s/+ass/([^/?]+)\.php [NC]
RewriteRule ^ /ass/%1 [R=301,L]

# ── Internal routing: clean URL → PHP file ────────────────────────────────────
# Root /ass/  →  login page
RewriteRule ^$ index.php [L]

# /ass/admin  →  admin/index.php
RewriteRule ^admin/?$ admin/index.php [L,QSA]

# /ass/X  →  X.php  (dashboard, grades, manage, submit, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [L,QSA]
