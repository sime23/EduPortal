# ── Root .htaccess – Assignment Portal ──────────────────────────────────────
RewriteEngine On
RewriteBase /

# Block direct access to sensitive directories
RewriteRule ^includes(/|$) - [F,L]
RewriteRule ^uploads(/|$)  - [F,L]

# ── 301 Canonical: strip .php from the browser address bar ───────────────────
# /admin/anything.php  →  /admin
RewriteCond %{THE_REQUEST} \s/+admin/[^/?]+\.php [NC]
RewriteRule ^ /admin [R=301,L]

# /X.php  →  /X
RewriteCond %{THE_REQUEST} \s/+([^/?]+)\.php [NC]
RewriteRule ^ /%1 [R=301,L]

# ── Internal routing: clean URL → PHP file ────────────────────────────────────
# Root /  →  login page
RewriteRule ^$ index.php [L]

# /admin  →  admin/index.php
RewriteRule ^admin/?$ admin/index.php [L,QSA]

# /X  →  X.php  (dashboard, grades, manage, submit, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [L,QSA]
